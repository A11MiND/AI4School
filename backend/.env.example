# Required in production
DATABASE_URL=postgresql://postgres:postgres@localhost/ai4school
JWT_SECRET_KEY=replace-with-a-random-string-at-least-32-chars
ONE_FOR_ALL_LAUNCH_SECRET=replace-with-the-shared-control-plane-launch-secret
ADAPTER_TOKEN=replace-with-control-plane-adapter-token

# Comma-separated allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3002,https://your-frontend-domain.vercel.app

# Optional
OPENAI_API_KEY=
GOOGLE_CLIENT_ID=
